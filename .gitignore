# No Backup files
*.bak 
# --- Simulation Files ---
sim/sim1/*.mpf
sim/sim1/*.mti
sim/sim1/*.wlf
sim/sim1/work/*
sim/sim1/work/@_opt/*
sim/sim1/*.mpf_new 
sim/sim1/transcript

sim/sim2/*.mpf
sim/sim2/*.mti
sim/sim2/*.wlf
sim/sim2/work/*
sim/sim2/*.mpf_new 
sim/sim2/transcript
sim/sim2/*.vstf
# Ignore all contents of the reports folder
sim/sim2/_reports/*

# Allow (un-ignore) the final summary files
# !sim/sim2/_reports/coverage_report.txt
# !sim/sim2/_reports/mips_coverage.ucdb

# --- Synthesis Files ---
# Database and temporary compilation files
syn/db/
syn/incremental_db/
syn/output_files/
syn/simulation/
syn/greybox_tmp/
syn/hps_isw_handoff/
syn/output_files/
syn/synthesis/

# Generated files that don't need tracking
